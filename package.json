{
  "name": "@s2j/docs-linter",
  "version": "1.0.11",
  "description": "Reusable textlint toolkit for Swift, WordPress, and general documentation projects.",
  "type": "module",
  "author": "Koutarou ISHIKAWA",
  "license": "GPL-2.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stein2nd/docs-linter.git"
  },
  "homepage": "https://github.com/stein2nd/docs-linter#readme",
  "bugs": {
    "url": "https://github.com/stein2nd/docs-linter/issues"
  },
  "keywords": [
    "textlint",
    "textlint-rule",
    "markdown",
    "wordpress",
    "swift"
  ],
  "engines": {
    "node": ">=20",
    "npm": ">=8 <11.12.0 || >=11.12.1"
  },
  "files": [
    "dist/",
    "presets/",
    "base/",
    "swift/",
    "wordpress/",
    "scripts/patch-wp-prh-colon-quote.cjs",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "main": "dist/bin/run-textlint.js",
  "bin": {
    "s2j-docs-linter": "dist/bin/run-textlint.js",
    "docs-lint": "dist/bin/run-textlint.js"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.build.json && node dist/scripts/setup-npmignore.js && node dist/scripts/link-preset-layout-compat.js",
    "prepare": "npm run build",
    "pack:check": "npm pack --dry-run",
    "pack:artifact": "mkdir -p artifacts && npm pack --pack-destination ./artifacts",
    "publish:dry-run": "npm publish --dry-run --access public",
    "lint:package": "npm pack --dry-run",
    "verify:tarball": "node ./scripts/verify-tarball.cjs",
    "verify:artifact": "npm run pack:artifact && node ./scripts/verify-tarball.cjs --from-artifacts",
    "dev": "npx vite build --watch",
    "lint": "node dist/bin/run-textlint.js './README.md' '**/*.md'",
    "lint:wp": "node dist/bin/run-textlint.js --profile wordpress './README.md' '**/*.md'",
    "lint:swift": "node dist/bin/run-textlint.js --profile swift './README.md' '**/*.md'",
    "postinstall": "node ./dist/scripts/setup-npmignore.js || true && node ./scripts/patch-wp-prh-colon-quote.cjs",
    "install:compat": "npx -y npm@11.11.0 install"
  },
  "overrides": {
    "rollup": "^4.60.4"
  },
  "dependencies": {
    "@textlint-ja/textlint-rule-no-synonyms": "^1.3.0",
    "sudachi-synonyms-dictionary": ">=4.0.1",
    "textlint": "^15.7.1",
    "textlint-filter-rule-allowlist": "^4.0.0",
    "textlint-filter-rule-comments": "^1.3.0",
    "textlint-rule-ja-hiragana-keishikimeishi": "^1.1.0",
    "textlint-rule-ja-no-abusage": "^3.0.0",
    "textlint-rule-ja-no-redundant-expression": "^4.0.1",
    "textlint-rule-ja-space-around-code": "^2.4.2",
    "textlint-rule-ja-space-between-half-and-full-width": "^2.4.2",
    "textlint-rule-max-kanji-continuous-len": "^1.1.1",
    "textlint-rule-no-dead-link": "^6.2.2",
    "textlint-rule-no-doubled-joshi": "^5.1.1",
    "textlint-rule-no-dropping-the-ra": "^3.0.0",
    "textlint-rule-no-mixed-zenkaku-and-hankaku-alphabet": "^1.0.1",
    "textlint-rule-preset-ja-technical-writing": "^12.0.2",
    "textlint-rule-preset-jtf-style": "^3.0.3",
    "textlint-rule-preset-swift-docs-ja": "github:stein2nd/textlint-rule-preset-swift-docs-ja",
    "textlint-rule-preset-wp-docs-ja": "github:jawordpressorg/textlint-rule-preset-wp-docs-ja",
    "textlint-rule-prh": "^6.1.0",
    "textlint-rule-terminology": "^5.2.16"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "rollup": "^4.60.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  }
}
